{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@domains/*": [
        "./domains/*"
      ],
      "@shared": [
        "./domains/shared/index.ts"
      ],
      "@shared/*": [
        "./domains/shared/*"
      ],
      "@auth": [
        "./domains/auth/index.ts"
      ],
      "@auth/*": [
        "./domains/auth/*"
      ],
      "@google-workspace": [
        "./domains/google-workspace/index.ts"
      ],
      "@google-workspace/*": [
        "./domains/google-workspace/*"
      ],
      "@whatsapp": [
        "./domains/whatsapp/index.ts"
      ],
      "@whatsapp/*": [
        "./domains/whatsapp/*"
      ],
      "@clients": [
        "./domains/clients/index.ts"
      ],
      "@clients/*": [
        "./domains/clients/*"
      ],
      "@inventory": [
        "./domains/inventory/index.ts"
      ],
      "@inventory/*": [
        "./domains/inventory/*"
      ],
      "@ai": [
        "./domains/ai/index.ts"
      ],
      "@ai/*": [
        "./domains/ai/*"
      ],
      "@site-builder": [
        "./domains/site-builder/index.ts"
      ],
      "@site-builder/*": [
        "./domains/site-builder/*"
      ],
      "@reports": [
        "./domains/reports/index.ts"
      ],
      "@reports/*": [
        "./domains/reports/*"
      ],
      "@infra/*": [
        "./infra/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}