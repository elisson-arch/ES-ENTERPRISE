{
    "extends": "./apps/web/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@apps/*": ["apps/*"],
            "@domains/*": ["domains/*"],
            "@infra/*": ["infra/*"],
            "@shared": ["domains/shared"],
            "@shared/*": ["domains/shared/*"],
            "@whatsapp": ["domains/whatsapp"],
            "@whatsapp/*": ["domains/whatsapp/*"],
            "@inventory": ["domains/inventory"],
            "@inventory/*": ["domains/inventory/*"],
            "@reports": ["domains/reports"],
            "@reports/*": ["domains/reports/*"],
            "@clients": ["domains/clients"],
            "@clients/*": ["domains/clients/*"],
            "@auth": ["domains/auth"],
            "@auth/*": ["domains/auth/*"],
            "@ai": ["domains/ai"],
            "@ai/*": ["domains/ai/*"],
            "@google-workspace": ["domains/google-workspace"],
            "@google-workspace/*": ["domains/google-workspace/*"],
            "@site-builder": ["domains/site-builder"],
            "@site-builder/*": ["domains/site-builder/*"]
        },
        "strict": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "apps/**/*.ts",
        "apps/**/*.tsx",
        "domains/**/*.ts",
        "domains/**/*.tsx",
        "scripts/**/*.ts",
        "scripts/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}