{
    "extends": "./apps/web/tsconfig.json",
    "compilerOptions": {
        "strict": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "apps/**/*.ts",
        "apps/**/*.tsx",
        "domains/**/*.ts",
        "domains/**/*.tsx",
        "scripts/**/*.ts",
        "scripts/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}