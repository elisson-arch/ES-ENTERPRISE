# ES-ENTERPRISE — Template de variáveis de ambiente
# NUNCA commitar o .env real. Copie este arquivo para .env e preencha os valores.
# Gerencie segredos de produção via GCP Secret Manager.

# ─── Firebase ───────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Google APIs ────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# ─── Gemini AI ──────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=

# ─── WhatsApp ───────────────────────────────────────────────────────────────
VITE_WHATSAPP_API_URL=
VITE_WHATSAPP_TOKEN=

# ─── App ────────────────────────────────────────────────────────────────────
VITE_APP_ENV=development
PORT=8080
