# ES-ENTERPRISE — Template de variáveis de ambiente
# NUNCA commitar o .env real. Copie este arquivo para .env e preencha os valores.
# Gerencie segredos de produção via GCP Secret Manager.

# ─── Firebase ───────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Google APIs ────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# ─── Gemini AI ──────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=

# ─── WhatsApp ───────────────────────────────────────────────────────────────
VITE_WHATSAPP_API_URL=
VITE_WHATSAPP_TOKEN=

VITE_APP_ENV=development
PORT=8080

# ─── Provedor de IA ──────────────────────────────────────────────────────────
# Qual IA usar: gemini | openai  (default: gemini)
VITE_AI_PROVIDER=gemini

# ─── Sentry (Error Monitoring) ──────────────────────────────────────────────
# Obtenha em: https://sentry.io > Seu projeto > Settings > Client Keys (DSN)
VITE_SENTRY_DSN=

# ─── Gemini API Key (Backend APENAS — NUNCA usar prefixo VITE_) ─────────────
API_KEY=

# ─── Firebase Admin SDK (Backend APENAS) ────────────────────────────────────
# Opção A: arquivo local → GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/key.json
# Opção B: JSON inline (recomendado Cloud Run) → cole o conteúdo do serviceAccount.json
FIREBASE_SERVICE_ACCOUNT_JSON=

