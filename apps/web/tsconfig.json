{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": "../..",
    "paths": {
      "@apps/*": ["apps/*"],
      "@domains/*": ["domains/*"],
      "@infra/*": ["infra/*"],
      "@shared": ["domains/shared"],
      "@shared/*": ["domains/shared/*"],
      "@whatsapp": ["domains/whatsapp"],
      "@whatsapp/*": ["domains/whatsapp/*"],
      "@inventory": ["domains/inventory"],
      "@inventory/*": ["domains/inventory/*"],
      "@reports": ["domains/reports"],
      "@reports/*": ["domains/reports/*"],
      "@clients": ["domains/clients"],
      "@clients/*": ["domains/clients/*"],
      "@auth": ["domains/auth"],
      "@auth/*": ["domains/auth/*"],
      "@ai": ["domains/ai"],
      "@ai/*": ["domains/ai/*"],
      "@google-workspace": ["domains/google-workspace"],
      "@google-workspace/*": ["domains/google-workspace/*"],
      "@site-builder": ["domains/site-builder"],
      "@site-builder/*": ["domains/site-builder/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}