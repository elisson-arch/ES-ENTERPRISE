{
  "name": "es-enterprise",
  "private": true,
  "version": "3.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"bgBlue,bgGreen\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite apps/web",
    "dev:api": "tsx watch apps/api/server.ts",
    "build": "npm run build:api && npm run build:web",
    "build:web": "tsc -p apps/web/tsconfig.json && vite build apps/web",
    "build:api": "tsc -p apps/api/tsconfig.api.json",
    "start": "node dist/api/server.js",
    "test": "vitest run --config apps/web/vitest.config.ts",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "@google/genai": "^1.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "express": "^4.19.2",
    "firebase": "^12.9.0",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.7",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.19.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
